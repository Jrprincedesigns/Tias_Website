{{ 'thetcollection.css' | asset_url | stylesheet_tag }}

<section class="tc-section tc-contact-wrap">
  <div class="tc-container">
    <div class="tc-contact-grid">
      <div class="tc-reveal">
        {%- form 'contact', class: 'tc-contact-form' -%}
          {%- if form.posted_successfully? -%}
            <div style="background: var(--tc-lavender-mist); padding: 18px 22px; border-radius: 12px; color: var(--tc-lavender-deep);">
              Thanks &mdash; we'll be in touch within 24 hours.
            </div>
          {%- elsif form.errors -%}
            <div style="background: #ffe5e5; padding: 18px 22px; border-radius: 12px; color: #b00;">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="tc-contact-row">
            <div class="tc-field">
              <label for="ContactFirst-{{ section.id }}">First name</label>
              <input id="ContactFirst-{{ section.id }}" type="text" name="contact[first_name]" autocomplete="given-name" required>
            </div>
            <div class="tc-field">
              <label for="ContactLast-{{ section.id }}">Last name</label>
              <input id="ContactLast-{{ section.id }}" type="text" name="contact[last_name]" autocomplete="family-name" required>
            </div>
          </div>
          <div class="tc-field">
            <label for="ContactEmail-{{ section.id }}">Email</label>
            <input id="ContactEmail-{{ section.id }}" type="email" name="contact[email]" autocomplete="email" required>
          </div>
          <div class="tc-field">
            <label for="ContactTopic-{{ section.id }}">{{ section.settings.topic_label | default: "What's this about?" }}</label>
            <select id="ContactTopic-{{ section.id }}" name="contact[topic]">
              {%- for block in section.blocks -%}
                {%- if block.type == 'topic' -%}
                  <option value="{{ block.settings.label | escape }}">{{ block.settings.label }}</option>
                {%- endif -%}
              {%- endfor -%}
            </select>
          </div>
          <div class="tc-field">
            <label for="ContactMessage-{{ section.id }}">Message</label>
            <textarea id="ContactMessage-{{ section.id }}" name="contact[body]" placeholder="{{ section.settings.message_placeholder | default: 'Tell us what you are looking for — the more detail, the better.' }}" required></textarea>
          </div>
          <button type="submit" class="tc-btn tc-btn--dark" style="justify-self: start;">
            {{ section.settings.submit_label | default: 'Send message' }} <span class="tc-arrow">&rarr;</span>
          </button>
        {%- endform -%}
      </div>

      <aside class="tc-contact-info tc-reveal">
        {%- for block in section.blocks -%}
          {%- if block.type == 'info' -%}
            <div class="tc-info-block">
              <h4>{{ block.settings.heading }}</h4>
              <p>{{ block.settings.body }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </aside>
    </div>
  </div>
</section>

{% render 'tc-reveal-script' %}

{% schema %}
{
  "name": "TC — Contact form",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "topic_label", "label": "Topic select label", "default": "What's this about?" },
    { "type": "text", "id": "message_placeholder", "label": "Message placeholder", "default": "Tell us what you're looking for — the more detail, the better." },
    { "type": "text", "id": "submit_label", "label": "Submit button label", "default": "Send message" }
  ],
  "blocks": [
    {
      "type": "topic",
      "name": "Topic option",
      "settings": [
        { "type": "text", "id": "label", "label": "Option label", "default": "General inquiry" }
      ]
    },
    {
      "type": "info",
      "name": "Info block (sidebar)",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Studio" },
        { "type": "richtext", "id": "body", "label": "Body", "default": "<p>By appointment only.<br/>Address sent at booking.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "TC — Contact form",
      "category": "TheTCollection",
      "blocks": [
        { "type": "topic", "settings": { "label": "General inquiry" } },
        { "type": "topic", "settings": { "label": "Preorder a unit" } },
        { "type": "topic", "settings": { "label": "Book the Wig Spa" } },
        { "type": "topic", "settings": { "label": "Order question" } },
        { "type": "info", "settings": { "heading": "Studio", "body": "<p>By appointment only.<br/>Address sent at booking.</p>" } },
        { "type": "info", "settings": { "heading": "Hours", "body": "<p>Tues - Sat \u00b7 10am - 6pm<br/>Sun - Mon \u00b7 closed</p>" } },
        { "type": "info", "settings": { "heading": "Email", "body": "<p><a href=\"mailto:hello@thetcollection.com\">hello@thetcollection.com</a></p>" } },
        { "type": "info", "settings": { "heading": "Response time", "body": "<p>Most messages answered within 24 hours, Tuesday through Saturday.</p>" } }
      ]
    }
  ]
}
{% endschema %}
