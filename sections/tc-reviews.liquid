{{ 'thetcollection.css' | asset_url | stylesheet_tag }}

<section class="tc-section tc-reviews">
  <div class="tc-container">
    {%- if section.settings.eyebrow != blank or section.settings.title != blank -%}
      <div class="tc-section-head tc-reveal">
        <div>
          {%- if section.settings.eyebrow != blank -%}<span class="tc-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
          {%- if section.settings.title != blank -%}<h2 class="tc-section-title">{{ section.settings.title }}</h2>{%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <div class="tc-review-grid">
      {%- for block in section.blocks -%}
        <div class="tc-review tc-reveal">
          <div class="tc-review__stars">{{ block.settings.stars | default: '★★★★★' }}</div>
          <p class="tc-review__quote">{{ block.settings.quote }}</p>
          <div class="tc-review__attr">
            <strong>{{ block.settings.name }}</strong>
            <span>{{ block.settings.meta }}</span>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% render 'tc-reveal-script' %}

{% schema %}
{
  "name": "TC — Reviews",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Loved by 18,400+" },
    { "type": "richtext", "id": "title", "label": "Title", "default": "<p>Reviewed five stars,<br/><em>worn</em> for years.</p>" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "stars", "label": "Stars (display)", "default": "★★★★★" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "I've worn extensions for ten years and these are by far the softest. TheTCollection has my loyalty." },
        { "type": "text", "id": "name", "label": "Reviewer name", "default": "Imani T." },
        { "type": "text", "id": "meta", "label": "Reviewer meta", "default": "Verified \u00b7 6 months" }
      ]
    }
  ],
  "presets": [
    {
      "name": "TC — Reviews",
      "category": "TheTCollection",
      "blocks": [
        { "type": "review" },
        { "type": "review", "settings": { "quote": "The shade match is uncanny. Three salon stylists asked me what I'd done to my own hair.", "name": "Rosa A.", "meta": "Verified \u00b7 1 year" } },
        { "type": "review", "settings": { "quote": "Worth every cent. They've held up through humidity, heat, and a wedding. Repeat customer.", "name": "Priya M.", "meta": "Verified \u00b7 8 months" } }
      ]
    }
  ]
}
{% endschema %}
