{{ 'thetcollection.css' | asset_url | stylesheet_tag }}

<section class="tc-section tc-pillars-wrap">
  <div class="tc-container">
    {%- if section.settings.eyebrow != blank
       or section.settings.title != blank
       or section.settings.intro != blank -%}
      <div class="tc-section-head tc-reveal">
        <div>
          {%- if section.settings.eyebrow != blank -%}
            <span class="tc-eyebrow">{{ section.settings.eyebrow }}</span>
          {%- endif -%}
          {%- if section.settings.title != blank -%}
            <h2 class="tc-section-title">{{ section.settings.title }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.intro != blank -%}
          <div class="tc-section-head__right">
            <p>{{ section.settings.intro }}</p>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="tc-pillars tc-reveal">
      {%- for block in section.blocks -%}
        <div class="tc-pillar">
          <div class="tc-pillar__num">{{ block.settings.number }}</div>
          <h3 class="tc-pillar__h">{{ block.settings.heading }}</h3>
          <div class="tc-pillar__p">{{ block.settings.body }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% render 'tc-reveal-script' %}

{% schema %}
{
  "name": "TC — Pillars",
  "tag": "section",
  "max_blocks": 3,
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "richtext", "id": "title", "label": "Title", "info": "Wrap a word in <em> for italic lavender accent." },
    { "type": "textarea", "id": "intro", "label": "Intro paragraph" }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number or label",
          "default": "01"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Single-donor sourced"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "info": "Rich text — paragraphs, line breaks, bullet lists.",
          "default": "<p>Every bundle traces back to one donor. Cuticles aligned, never blended with synthetic or commodity hair.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TC — Pillars",
      "category": "TheTCollection",
      "blocks": [
        { "type": "pillar", "settings": { "number": "01", "heading": "Single-donor sourced", "body": "Every bundle traces back to one donor. Cuticles aligned, never blended with synthetic or commodity hair." } },
        { "type": "pillar", "settings": { "number": "02", "heading": "Hand-wefted in-studio", "body": "No machine wefts. Each strand sewn by hand for a flatter base, lighter wear, and longer life." } },
        { "type": "pillar", "settings": { "number": "03", "heading": "Shade-matched by eye", "body": "Twenty-four custom-blended shades. Take the quiz or send a photo \u2014 we'll never guess." } }
      ]
    }
  ]
}
{% endschema %}
