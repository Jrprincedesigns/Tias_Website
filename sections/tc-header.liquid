{{ 'thetcollection.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign menu = linklists[section.settings.menu]
  assign show_search = section.settings.show_search
  assign show_account = section.settings.show_account
-%}

<header class="tc-nav" role="banner">
  <div class="tc-container">
    <div class="tc-nav__row">

      {%- comment -%} LEFT UTILITY: hamburger (mobile only) + search {%- endcomment -%}
      <div class="tc-nav__utility">
        <button
          type="button"
          class="tc-nav__hamburger"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="tc-nav-drawer"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
        {%- if show_search -%}
          <a href="{{ routes.search_url }}" class="tc-icon-btn" aria-label="{{ 'general.search.search' | t }}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <circle cx="11" cy="11" r="7"/>
              <path d="m20 20-3.5-3.5"/>
            </svg>
          </a>
          <a href="{{ routes.search_url }}" class="tc-label-sm">{{ 'general.search.search' | t }}</a>
        {%- endif -%}
      </div>

      {%- comment -%}
        CENTER: wordmark or uploaded logo. Always a plain link — the page's
        h1 lives in the hero (or main content), not in the header.
      {%- endcomment -%}
      <a href="{{ routes.root_url }}" class="tc-wordmark">
        {%- if settings.logo != blank -%}
          {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
          {{ settings.logo | image_url: width: 600 | image_tag:
               class: 'tc-wordmark__logo',
               widths: '200, 300, 400, 600',
               sizes: '(max-width: 760px) 200px, 300px',
               alt: logo_alt,
               loading: 'eager' }}
        {%- else -%}
          <span class="tc-wordmark__name">{{ shop.name }}</span>
          {%- if section.settings.tagline != blank -%}
            <span class="tc-wordmark__sub">{{ section.settings.tagline }}</span>
          {%- endif -%}
        {%- endif -%}
      </a>

      {%- comment -%} RIGHT UTILITY: account, cart {%- endcomment -%}
      <div class="tc-nav__utility tc-nav__utility--right">
        {%- if show_account and shop.customer_accounts_enabled -%}
          {%- if customer -%}
            <a href="{{ routes.account_url }}" class="tc-label-sm">{{ 'customer.account_fallback' | t }}</a>
          {%- else -%}
            <a href="{{ routes.account_login_url }}" class="tc-label-sm">{{ 'customer.log_in' | t }}</a>
          {%- endif -%}
        {%- endif -%}

        <a
          href="{{ routes.cart_url }}"
          class="tc-icon-btn"
          aria-label="{{ 'templates.cart.cart' | t }} ({{ cart.item_count }})"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M5 8h14l-1.5 11a2 2 0 0 1-2 1.7H8.5A2 2 0 0 1 6.5 19L5 8z"/>
            <path d="M9 8V6a3 3 0 0 1 6 0v2"/>
          </svg>
          {%- if cart.item_count > 0 -%}
            <span class="tc-cart-count" aria-hidden="true">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
      </div>
    </div>

    {%- if menu != blank and menu.links.size > 0 -%}
      <nav class="tc-nav__links" aria-label="{{ 'sections.header.primary_navigation' | t }}">
        {%- for link in menu.links -%}
          <a
            href="{{ link.url }}"
            class="{% if link.active or link.child_active %}is-active{% endif %}"
          >{{ link.title | escape }}</a>
        {%- endfor -%}
      </nav>
    {%- endif -%}
  </div>
</header>

{%- if menu != blank and menu.links.size > 0 -%}
  <div class="tc-nav-drawer" id="tc-nav-drawer" aria-hidden="true">
    <div class="tc-nav-drawer__backdrop" data-tc-drawer-close></div>
    <aside class="tc-nav-drawer__panel" role="dialog" aria-modal="true" aria-label="Menu">
      <div class="tc-nav-drawer__head">
        <span class="tc-nav-drawer__brand">{{ shop.name }}</span>
        <button
          type="button"
          class="tc-nav-drawer__close"
          aria-label="Close menu"
          data-tc-drawer-close
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M6 6l12 12M18 6L6 18"/>
          </svg>
        </button>
      </div>
      <nav class="tc-nav-drawer__links" aria-label="Mobile menu">
        {%- for link in menu.links -%}
          <a
            href="{{ link.url }}"
            class="{% if link.active or link.child_active %}is-active{% endif %}"
          >{{ link.title | escape }}</a>
        {%- endfor -%}
        {%- if show_account and shop.customer_accounts_enabled -%}
          <span class="tc-nav-drawer__divider" aria-hidden="true"></span>
          {%- if customer -%}
            <a href="{{ routes.account_url }}" class="tc-nav-drawer__util">{{ 'customer.account_fallback' | t }}</a>
          {%- else -%}
            <a href="{{ routes.account_login_url }}" class="tc-nav-drawer__util">{{ 'customer.log_in' | t }}</a>
          {%- endif -%}
        {%- endif -%}
      </nav>
    </aside>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "TC — Header",
  "class": "tc-header-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu",
      "info": "Top-level links only — dropdowns are not supported in this layout."
    },
    {
      "type": "header",
      "content": "Wordmark"
    },
    {
      "type": "paragraph",
      "content": "If you set a logo image in Theme settings → Logo, it will replace the typeset wordmark below."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Premium Custom Hair",
      "info": "Small uppercase line under the typeset wordmark. Shown only when no logo image is uploaded."
    },
    {
      "type": "header",
      "content": "Utility"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account link",
      "default": true,
      "info": "Hidden automatically if customer accounts are disabled."
    }
  ],
  "presets": [
    {
      "name": "TC — Header",
      "category": "TheTCollection"
    }
  ]
}
{% endschema %}
