{{ 'thetcollection.css' | asset_url | stylesheet_tag }}

<section class="tc-section tc-curated">
  <div class="tc-container">
    <div class="tc-curated__grid">

      <div class="tc-curated__copy tc-reveal">
        {%- if section.settings.eyebrow != blank -%}
          <span class="tc-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="tc-curated__title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <div class="tc-curated__body">{{ section.settings.body }}</div>
        {%- endif -%}
      </div>

      <div class="tc-curated__media tc-reveal">
        {%- if section.blocks.size > 0 -%}
          <div class="tc-curated__cards" data-count="{{ section.blocks.size }}">
            {%- for block in section.blocks -%}
              {%- assign card_link = block.settings.link | default: '#' -%}
              {%- assign card_external = false -%}
              {%- if card_link contains 'http' -%}{%- assign card_external = true -%}{%- endif -%}
              <a
                class="tc-curated__card"
                href="{{ card_link }}"
                {% if card_external %}target="_blank" rel="noopener"{% endif %}
                aria-label="{{ block.settings.alt | default: 'Product link' }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 800 | image_tag:
                       class: 'tc-curated__img',
                       loading: 'lazy',
                       widths: '300, 500, 800',
                       sizes: '(min-width: 880px) 22vw, 45vw',
                       alt: block.settings.image.alt | default: block.settings.alt | default: '' }}
                {%- else -%}
                  <div class="tc-curated__placeholder" aria-hidden="true">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                      <rect x="3" y="5" width="18" height="14" rx="2"/>
                      <circle cx="9" cy="11" r="1.5"/>
                      <path d="m3 17 5-5 4 4 3-3 6 6"/>
                    </svg>
                  </div>
                {%- endif -%}
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          {%- assign cta_link = section.settings.cta_link | default: '#' -%}
          {%- assign cta_external = false -%}
          {%- if cta_link contains 'http' -%}{%- assign cta_external = true -%}{%- endif -%}
          <a
            class="tc-btn tc-btn--lavender tc-curated__cta"
            href="{{ cta_link }}"
            {% if cta_external %}target="_blank" rel="noopener"{% endif %}
          >
            {{ section.settings.cta_label }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% render 'tc-reveal-script' %}

{% schema %}
{
  "name": "TC — Curated picks",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "header", "content": "Copy" },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Products we trust"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "info": "Wrap a word in <em> for italic lavender accent.",
      "default": "<p>What we use, <em>recommend</em>, and stand behind.</p>"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Below is a curated list of products we love and trust, carefully selected to support proper cleansing, moisture balance, and styling.</p>"
    },
    { "type": "header", "content": "Call to action" },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop on amazon"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link",
      "info": "External links open in a new tab automatically."
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Product card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Square crop recommended. Falls back to a placeholder pattern if empty."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Where this card sends the user (e.g. an Amazon product page). Opens in a new tab if it's an external link."
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Accessible label",
          "info": "Used as the link's aria-label and image alt if no image alt is set."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TC — Curated picks",
      "category": "TheTCollection",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
