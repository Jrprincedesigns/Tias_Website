{{ 'thetcollection.css' | asset_url | stylesheet_tag }}

<section class="tc-section tc-bento-wrap">
  <div class="tc-container">
    {%- if section.settings.eyebrow != blank
       or section.settings.title != blank
       or section.settings.intro != blank -%}
      <div class="tc-section-head tc-reveal">
        <div>
          {%- if section.settings.eyebrow != blank -%}
            <span class="tc-eyebrow">{{ section.settings.eyebrow }}</span>
          {%- endif -%}
          {%- if section.settings.title != blank -%}
            <h2 class="tc-section-title">{{ section.settings.title }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.intro != blank -%}
          <div class="tc-section-head__right">
            <p>{{ section.settings.intro }}</p>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="tc-bento tc-reveal">
      {%- for block in section.blocks -%}
        {%- liquid
          assign position = forloop.index
          if position > 4
            assign position = 4
          endif

          assign product_obj = block.settings.product
          assign collection_obj = block.settings.collection

          assign href = '#'
          if block.settings.link != blank
            assign href = block.settings.link
          elsif product_obj != blank
            assign href = product_obj.url
          elsif collection_obj != blank
            assign href = collection_obj.url
          endif

          assign cell_image = block.settings.image
          if cell_image == blank and product_obj.featured_image != blank
            assign cell_image = product_obj.featured_image
          endif
          if cell_image == blank and collection_obj.image != blank
            assign cell_image = collection_obj.image
          endif

          assign cell_name = block.settings.name
          if cell_name == blank and product_obj.title != blank
            assign cell_name = product_obj.title
          endif
          if cell_name == blank and collection_obj.title != blank
            assign cell_name = collection_obj.title
          endif

          assign cell_meta = block.settings.meta
          if cell_meta == blank and product_obj != blank
            assign cell_meta = product_obj.price | money
          endif
          if cell_meta == blank and collection_obj != blank
            assign count = collection_obj.products_count
            assign cell_meta = count | append: ' products'
          endif

          assign tag_class = 'tc-bento-cell__tag'
          if block.settings.tag_hot
            assign tag_class = tag_class | append: ' tc-bento-cell__tag--hot'
          endif
        -%}

        <a
          class="tc-bento-cell tc-bento-cell--{{ position }}"
          href="{{ href }}"
          {{ block.shopify_attributes }}
        >
          {%- if cell_image != blank -%}
            {{ cell_image | image_url: width: 1200 | image_tag:
                 class: 'tc-bento-cell__image',
                 widths: '400, 600, 900, 1200',
                 sizes: '(min-width: 880px) 50vw, 100vw',
                 loading: 'lazy',
                 alt: cell_image.alt | default: cell_name | strip_html }}
          {%- endif -%}

          {%- if position == 1 -%}
            <svg
              class="tc-bento-deco"
              viewBox="0 0 200 200"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path d="M50,20 Q90,80 60,140 T80,200" stroke="white" stroke-width="1.5" fill="none"/>
              <path d="M90,10 Q130,70 100,140 T120,200" stroke="white" stroke-width="1.5" fill="none"/>
              <path d="M130,20 Q170,90 140,150 T160,200" stroke="white" stroke-width="1.5" fill="none"/>
            </svg>
          {%- endif -%}

          <div>
            {%- if block.settings.tag != blank -%}
              <span class="{{ tag_class }}">{{ block.settings.tag }}</span>
            {%- elsif block.settings.kicker != blank -%}
              <span class="tc-bento-meta tc-bento-meta--top">{{ block.settings.kicker }}</span>
            {%- endif -%}
          </div>

          <div>
            {%- if cell_name != blank -%}
              <div class="tc-bento-name">{{ cell_name }}</div>
            {%- endif -%}
            {%- if cell_meta != blank -%}
              <div class="tc-bento-meta" style="margin-top: 18px;">
                <span>{{ cell_meta }}</span>
                <span aria-hidden="true">→</span>
              </div>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% render 'tc-reveal-script' %}

{% schema %}
{
  "name": "TC — Bento grid",
  "tag": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Collection"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "info": "Wrap a word in <em> for italic lavender accent.",
      "default": "<p>Built for every <em>texture</em>, every tone.</p>"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro paragraph",
      "default": "Six core silhouettes, blended into 24 shades. Find the one that disappears into yours."
    },
    {
      "type": "header",
      "content": "Layout note",
      "info": "The first block is the large feature cell. Add up to three more blocks for the right side."
    }
  ],
  "blocks": [
    {
      "type": "cell",
      "name": "Cell",
      "settings": [
        {
          "type": "header",
          "content": "Source"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "If set, the cell auto-fills with the product's image, title, price, and link. Override fields below take precedence."
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection (alternative)",
          "info": "Used if no product is selected above. Auto-fills with the collection's image, title, and product count."
        },
        {
          "type": "header",
          "content": "Tag badge"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag",
          "info": "Small pill in the top-left, e.g. \"Best seller\", \"New\", \"Limited\". Replaces the kicker if both are set."
        },
        {
          "type": "checkbox",
          "id": "tag_hot",
          "label": "Solid pill style",
          "default": false,
          "info": "Solid lavender background instead of the default outlined style."
        },
        {
          "type": "header",
          "content": "Overrides"
        },
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker (fallback when no tag)",
          "info": "Plain text label shown only when no tag is set."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Override name",
          "info": "Leave empty to use the product/collection title. Use <br/> for a line break."
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Override meta line",
          "info": "Leave empty to show the product price or collection product count."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override image",
          "info": "Optional. Falls back to the product or collection image if set."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Override link",
          "info": "Optional. Overrides the product/collection link."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TC — Bento grid",
      "category": "TheTCollection",
      "blocks": [
        { "type": "cell", "settings": { "tag": "Best seller", "tag_hot": true } },
        { "type": "cell", "settings": { "tag": "Loved" } },
        { "type": "cell", "settings": { "tag": "New" } },
        { "type": "cell", "settings": { "tag": "Limited", "tag_hot": true } }
      ]
    }
  ]
}
{% endschema %}
