{{ 'thetcollection.css' | asset_url | stylesheet_tag }}

<section class="tc-section tc-bento-wrap">
  <div class="tc-container">
    {%- if section.settings.eyebrow != blank or section.settings.title != blank or section.settings.intro != blank -%}
      <div class="tc-section-head tc-reveal">
        <div>
          {%- if section.settings.eyebrow != blank -%}<span class="tc-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
          {%- if section.settings.title != blank -%}<h2 class="tc-section-title">{{ section.settings.title }}</h2>{%- endif -%}
        </div>
        {%- if section.settings.intro != blank -%}
          <div class="tc-section-head__right"><p>{{ section.settings.intro }}</p></div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="tc-bento tc-reveal">
      {%- for block in section.blocks -%}
        {%- assign cell_class = 'tc-bento-cell tc-bento-cell--' | append: block.settings.style -%}
        {%- if forloop.first -%}
          {%- assign cell_class = cell_class | append: ' tc-bento-cell--feature' -%}
        {%- endif -%}
        <a class="{{ cell_class }}" href="{{ block.settings.link | default: '#' }}">
          <div>
            <span class="tc-bento-meta" style="opacity: 0.7;">{{ block.settings.kicker }}</span>
          </div>
          <div>
            <h3 class="tc-bento-name">{{ block.settings.name }}</h3>
            {%- if block.settings.meta != blank -%}
              <div class="tc-bento-meta" style="margin-top: 14px;">
                <span>{{ block.settings.meta }}</span>
                <span>&rarr;</span>
              </div>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% render 'tc-reveal-script' %}

{% schema %}
{
  "name": "TC — Bento grid",
  "tag": "section",
  "max_blocks": 5,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Collection" },
    { "type": "richtext", "id": "title", "label": "Title", "default": "<p>Built for every <em>texture</em>, every tone.</p>" },
    { "type": "textarea", "id": "intro", "label": "Intro paragraph", "default": "Six core silhouettes, blended into 24 shades. Find the one that disappears into yours." }
  ],
  "blocks": [
    {
      "type": "cell",
      "name": "Cell",
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker (top-left)", "default": "01" },
        { "type": "text", "id": "name", "label": "Name", "default": "Hair Extensions" },
        { "type": "text", "id": "meta", "label": "Meta line (bottom)", "default": "42 styles" },
        { "type": "url", "id": "link", "label": "Link" },
        {
          "type": "select",
          "id": "style",
          "label": "Color style",
          "options": [
            { "value": "mist", "label": "Lavender mist" },
            { "value": "cream", "label": "Cream" },
            { "value": "lavender", "label": "Solid lavender" },
            { "value": "paper", "label": "Paper white" }
          ],
          "default": "mist"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TC — Bento grid",
      "category": "TheTCollection",
      "blocks": [
        { "type": "cell", "settings": { "kicker": "01 / Bestselling", "name": "Hair Extensions", "meta": "42 styles \u00b7 From $95" } },
        { "type": "cell", "settings": { "kicker": "02", "name": "Preorder a Unit", "meta": "14 styles", "style": "mist" } },
        { "type": "cell", "settings": { "kicker": "03", "name": "The Wig Spa", "meta": "From $75", "style": "cream" } },
        { "type": "cell", "settings": { "kicker": "04", "name": "Hair Care", "meta": "12 items", "style": "lavender" } },
        { "type": "cell", "settings": { "kicker": "05", "name": "Add-Ons", "meta": "22 items", "style": "paper" } }
      ]
    }
  ]
}
{% endschema %}
