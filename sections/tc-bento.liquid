{{ 'thetcollection.css' | asset_url | stylesheet_tag }}

<section class="tc-section tc-bento-wrap">
  <div class="tc-container">
    {%- if section.settings.eyebrow != blank
       or section.settings.title != blank
       or section.settings.intro != blank -%}
      <div class="tc-section-head tc-reveal">
        <div>
          {%- if section.settings.eyebrow != blank -%}
            <span class="tc-eyebrow">{{ section.settings.eyebrow }}</span>
          {%- endif -%}
          {%- if section.settings.title != blank -%}
            <h2 class="tc-section-title">{{ section.settings.title }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.intro != blank -%}
          <div class="tc-section-head__right">
            <p>{{ section.settings.intro }}</p>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="tc-bento tc-reveal">
      {%- for block in section.blocks -%}
        {%- liquid
          # Position class — caps at 5 even if more blocks somehow exist
          assign position = forloop.index
          if position > 5
            assign position = 5
          endif

          # href priority: manual link > collection URL > #
          assign href = '#'
          if block.settings.link != blank
            assign href = block.settings.link
          elsif block.settings.collection != blank
            assign href = block.settings.collection.url
          endif

          # Image priority: explicit image > collection.featured_image
          assign cell_image = block.settings.image
          if cell_image == blank and block.settings.collection.image != blank
            assign cell_image = block.settings.collection.image
          endif

          # Default name: explicit > collection title
          assign cell_name = block.settings.name
          if cell_name == blank and block.settings.collection.title != blank
            assign cell_name = block.settings.collection.title
          endif

          # Default meta: explicit > "{count} products"
          assign cell_meta = block.settings.meta
          if cell_meta == blank and block.settings.collection != blank
            assign count = block.settings.collection.products_count
            assign cell_meta = count | append: ' products'
          endif
        -%}

        <a
          class="tc-bento-cell tc-bento-cell--{{ position }}"
          href="{{ href }}"
          {{ block.shopify_attributes }}
        >
          {%- if cell_image != blank -%}
            {{ cell_image | image_url: width: 1200 | image_tag:
                 class: 'tc-bento-cell__image',
                 widths: '400, 600, 900, 1200',
                 sizes: '(min-width: 880px) 50vw, 100vw',
                 loading: 'lazy',
                 alt: cell_image.alt | default: cell_name | strip_html }}
          {%- endif -%}

          {%- if position == 1 -%}
            <svg
              class="tc-bento-deco"
              viewBox="0 0 200 200"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path d="M50,20 Q90,80 60,140 T80,200" stroke="white" stroke-width="1.5" fill="none"/>
              <path d="M90,10 Q130,70 100,140 T120,200" stroke="white" stroke-width="1.5" fill="none"/>
              <path d="M130,20 Q170,90 140,150 T160,200" stroke="white" stroke-width="1.5" fill="none"/>
            </svg>
          {%- endif -%}

          <div>
            <span class="tc-bento-meta tc-bento-meta--top">{{ block.settings.kicker }}</span>
          </div>

          <div>
            {%- if cell_name != blank -%}
              <div class="tc-bento-name">{{ cell_name }}</div>
            {%- endif -%}
            {%- if cell_meta != blank -%}
              <div class="tc-bento-meta" style="margin-top: 18px;">
                <span>{{ cell_meta }}</span>
                <span aria-hidden="true">→</span>
              </div>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% render 'tc-reveal-script' %}

{% schema %}
{
  "name": "TC — Bento grid",
  "tag": "section",
  "max_blocks": 5,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Collection"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "info": "Wrap a word in <em> for italic lavender accent.",
      "default": "<p>Built for every <em>texture</em>, every tone.</p>"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro paragraph",
      "default": "Six core silhouettes, blended into 24 shades. Find the one that disappears into yours."
    },
    {
      "type": "header",
      "content": "Layout note",
      "info": "The first block is the large feature cell. Add up to four more blocks for the right side."
    }
  ],
  "blocks": [
    {
      "type": "cell",
      "name": "Cell",
      "settings": [
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker (top-left)",
          "default": "01"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection",
          "info": "The cell will link here. The collection's title and product count will be used unless overridden below."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Override name",
          "info": "Leave empty to use the collection's title. Use <br/> for a line break."
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Override meta line",
          "info": "Leave empty to show '{count} products' from the collection."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override image",
          "info": "Optional. Falls back to the collection image if set, or to a flat color if neither is provided."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Override link",
          "info": "Optional. Overrides the collection link."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TC — Bento grid",
      "category": "TheTCollection",
      "blocks": [
        { "type": "cell", "settings": { "kicker": "01 / Bestselling" } },
        { "type": "cell", "settings": { "kicker": "02" } },
        { "type": "cell", "settings": { "kicker": "03" } },
        { "type": "cell", "settings": { "kicker": "04" } },
        { "type": "cell", "settings": { "kicker": "05" } }
      ]
    }
  ]
}
{% endschema %}
